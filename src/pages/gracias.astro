---
import Layout from '../layouts/Layout.astro';
---

<Layout description="Tu solicitud de cotización fue enviada correctamente. Un especialista de cuenta de Energex se pondrá en contacto contigo." title="Solicitud Enviada">
	<section class="py-24 bg-white min-h-[60vh] flex items-center">
		<div class="max-w-2xl mx-auto px-6 text-center">
			<div class="w-16 h-16 rounded-full bg-green-100 text-green-600 flex items-center justify-center mx-auto mb-6">
				<i class="ph ph-check-circle text-4xl"></i>
			</div>
			<span class="text-[10px] font-bold uppercase tracking-widest text-brand-primary bg-brand-primary/10 px-3 py-1 rounded-full">Solicitud Recibida</span>
			<h1 class="text-2xl md:text-4xl font-black tracking-tight text-brand-dark mt-4">¡Gracias por tu solicitud!</h1>
			<p class="text-sm md:text-base text-brand-text mt-4 leading-relaxed">
				Hemos recibido tu solicitud de cotización correctamente. Un especialista de cuenta de Energex se pondrá en contacto a la brevedad.
			</p>
			<a href="/" class="inline-flex items-center gap-2 bg-brand-primary text-white text-xs font-bold uppercase tracking-wider px-6 py-3 rounded mt-8 hover:bg-red-700 transition-colors">
				Volver al inicio
			</a>
		</div>
	</section>
</Layout>
