									<option value="" disabled selected>Selecciona una opción..</option>
									<option value="Si">Si</option>
									<option value="No">No</option>
								</select>
							</div>
						</div>


						<div class="pt-4">
							<button type="submit" class="w-full bg-brand-primary text-white font-bold uppercase tracking-wider py-4 rounded-xl shadow-lg hover:bg-red-700 transition-all text-center cursor-pointer">
								Enviar Solicitud
							</button>
						</div>
					</div>
				</form>
			</div>
		</div>
